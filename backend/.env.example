DATABASE_URL=postgresql+asyncpg://menu:menu@localhost:5432/menu_dev
SECRET_KEY=changeme-use-a-long-random-string
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
APP_NAME=Menu

# Cloudflare R2 — object storage for product/logo images (M4, not implemented yet).
# S3-compatible: same boto3 client as AWS S3, pointed at R2_ENDPOINT_URL.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=menu-test
# Public read URL for serving images (r2.dev subdomain or a custom domain
# attached to the bucket) — enable "Public Access" on the bucket first.
R2_PUBLIC_URL=
